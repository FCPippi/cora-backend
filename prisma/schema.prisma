// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id_user      Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  password     String
  user_type    String
  avatar       String
  join_date    DateTime


  // Relações
  children      child[]
  replies       reply[]
  questions     question[]
  modules       module[] @relation("user_modules")
  profile       specialist_profile?
}

model child {
  id_child   Int      @id @default(autoincrement())
  name       String
  birth_date DateTime
  age_group  String

  // Relações
  user_id    Int
  user       user @relation(fields: [user_id], references: [id_user])
}

model reply {
  id_reply      Int      @id @default(autoincrement())
  text          String
  is_anonymous  Boolean  @default(false)
  creation_date DateTime @default(now())

  // Relações
  user_id      Int
  user         user    @relation(fields: [user_id], references: [id_user])
  question_id  Int
  question     question @relation(fields: [question_id], references: [id_question])
}

model question {
  id_question   Int      @id @default(autoincrement())
  title         String
  text          String
  creation_date DateTime @default(now())
  keywords      String
  is_anonymous  Boolean  @default(false)

  // Relações
  user_id  Int
  user     user    @relation(fields: [user_id], references: [id_user])
  replies  reply[]
}

model module {
  id_module     Int      @id @default(autoincrement())
  title         String
  sinopsys      String
  thumbnail     String
  creation_date DateTime @default(now())
  views         Int      @default(0)
  age_group     String

  // Relações
  user_id  Int
  user     user @relation("user_modules", fields: [user_id], references: [id_user])
  contents content[]
}

model content {
  id_content  Int      @id @default(autoincrement())
  text        String?
  image       String?
  template    String
  video_link  String?

  module_id Int
  module    module @relation(fields: [module_id], references: [id_module])
}

model specialist_profile {
  id_specialist  Int     @id @default(autoincrement())
  specialty      String
  photo          String
  description    String
  council_number String

  user_id    Int  @unique
  user       user @relation(fields: [user_id], references: [id_user])
}
